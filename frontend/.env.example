# Copy to .env. Values prefixed with VITE_ are exposed to the browser.

# Base URL the frontend uses to call the API. In dev we proxy through Vite,
# so leaving this as /api/v1 lets relative requests hit the proxy.
VITE_API_BASE_URL=/api/v1

# Used by vite.config.ts for the dev proxy target (server-side, not exposed).
VITE_API_PROXY_TARGET=http://backend:8000

# Public WhatsApp number for click-to-chat (E.164, no +). Filled in Module 7.
VITE_WHATSAPP_NUMBER=
