# Copy to .env and fill in real values. .env is gitignored.

# --- Django ---
DJANGO_SETTINGS_MODULE=ecomart.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# --- Database (matches docker-compose `db` service) ---
DATABASE_URL=postgres://ecomart:ecomart@db:5432/ecomart
CONN_MAX_AGE=60

# Postgres image variables (read by the db service in docker-compose)
POSTGRES_DB=ecomart
POSTGRES_USER=ecomart
POSTGRES_PASSWORD=ecomart

# --- Cache / broker ---
REDIS_URL=redis://redis:6379/0

# --- CORS (frontend origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- WhatsApp (filled in Module 7) ---
WHATSAPP_BUSINESS_NUMBER=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
